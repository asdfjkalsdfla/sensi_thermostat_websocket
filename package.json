{
  "name": "sensi_thermostat_websocket",
  "packageManager": "pnpm@10.18.3",
  "version": "0.0.1",
  "type": "module",
  "dependencies": {
    "@google-cloud/pubsub": "^5.3.0",
    "aht20-sensor": "^0.1.1",
    "dotenv": "^17.4.0",
    "express": "^5.2.1",
    "lodash": "^4.18.1",
    "prom-client": "^15.1.3",
    "socket.io-client": "^2.5.0",
    "typescript": "^6.0.2"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.4.0",
    "@types/node": "^22.19.17",
    "@vitest/coverage-v8": "^4.1.2",
    "esbuild": "^0.25.12",
    "oxlint": "^1.58.0",
    "undici": "^8.0.2",
    "vitest": "^4.1.2"
  },
  "scripts": {
    "start": "ts-node-esm src/index.ts",
    "build": "./esbuild.cjs",
    "check": "tsc -p tsconfig.build.json",
    "test": "vitest",
    "coverage": "vitest run --coverage",
    "lint": "oxlint src/"
  },
  "jest": {
    "clearMocks": true,
    "collectCoverage": true,
    "coverageReporters": [
      "json",
      "html"
    ],
    "preset": "ts-jest/presets/default-esm",
    "extensionsToTreatAsEsm": [
      ".ts",
      ".tsx"
    ],
    "testEnvironment": "node",
    "globals": {
      "ts-jest": {
        "useESM": true
      }
    },
    "moduleNameMapper": {
      "(.*)\\.js$": "$1"
    },
    "coverageDirectory": "./coverage/",
    "setupFilesAfterEnv": [
      "jest-extended/all"
    ],
    "roots": [
      "./test"
    ]
  }
}
