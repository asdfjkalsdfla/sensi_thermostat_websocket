{
  "project": "sensi_thermostat_websocket",
  "compilerOptions": {
    "emitDeclarationOnly": true,
    "declaration": true,
    "module": "preserve",
    "target": "es2025",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": false,
    "typeRoots": [
      "node_modules/@types"
    ],
    "types": [
      "node"
    ],
    "lib": [
      "es2025",
      "dom"
    ],
    "sourceMap": true,
    "allowJs": true,
    "outDir": "build/"
  },
  "include": [
    "src/**/*",
    "test/**/*"
  ]
}